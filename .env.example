# =============================================================================
# AI provider keys
# =============================================================================
# Used in server-side routes only. Never expose to the client.

# Google Generative AI (Gemini 2.5 Flash Image, a.k.a. "Nano Banana")
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic (Claude vision + quote selection + style extraction)
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Fal (Whisper transcription fallback when YouTube subtitles are missing)
# Get one at https://fal.ai/dashboard/keys
FAL_KEY=

# =============================================================================
# Demo-mode access control
# =============================================================================
# The passcode that gates demo-mode access. Visitors paste it in the UI.
# In BYOK mode, this is not used — visitors supply their own keys.
DEMO_PASSCODE=

# Hard daily spend cap (USD) across all demo-mode requests using the server keys.
# When exceeded, demo mode is disabled until the next UTC day. BYOK is unaffected.
DEMO_DAILY_SPEND_CAP_USD=5

# =============================================================================
# Vercel resources (auto-populated by `vercel env pull` after Marketplace install)
# =============================================================================

# Vercel Blob — finished thumbnails (public) + intermediate artifacts (private)
BLOB_READ_WRITE_TOKEN=

# Neon Postgres — run metadata, style presets, eval results
DATABASE_URL=

# Upstash Redis — rate limiting + daily spend counters
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# Vercel Sandbox (yt-dlp + ffmpeg)
# =============================================================================
# On Vercel deployments these come from OIDC automatically.
# For local dev with `next dev`, provide a personal access token + IDs.
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# Pre-built sandbox snapshot with yt-dlp + ffmpeg installed (sub-second cold start).
# Created by running `npx tsx scripts/create-sandbox-snapshot.ts`.
INGEST_SANDBOX_SNAPSHOT_ID=
