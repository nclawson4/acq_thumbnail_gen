# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# env files — never commit any
.env
.env.*
!.env.example

# secrets / credentials (defensive — should never live here, but extra safety)
*.pem
*.key
*.p12
*.pfx
secrets/
credentials.json
service-account*.json

# runtime artifacts (downloaded videos, intermediate thumbnails, scratch files)
tmp/
artifacts/
scratch/
.scratch/
*.mp4
*.webm
*.mkv
*.mov

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# eval outputs (large, can regenerate)
evals/results/

.vercel
.env*.local
